# Copy this file to .env and fill in your values for docker-compose

# Telegram bot token (required)
TELEGRAM_TOKEN=123456789:ABCDEFGHIJKLMNOPQRSTUVWXYZ

# Torrent client (qbittorrent)
TORRENT_CLIENT=qbittorrent

# qBittorrent settings (default)
QBITTORRENT_HOST=localhost
QBITTORRENT_PORT=8080
QBITTORRENT_USERNAME=admin
QBITTORRENT_PASSWORD=adminadmin

# qBittorrent container file ownership (PUID:PGID) and umask.
# Set PGID to the GID of the user that consumes downloads (e.g. Plex)
# and UMASK=002 so files are group-writable for that consumer.
# Example: QBITTORRENT_PGID=10001  # plex group on the NAS
QBITTORRENT_PUID=1000
QBITTORRENT_PGID=1000
QBITTORRENT_UMASK=002

# Authorized user IDs (comma-separated)
USERS_WHITE_LIST=123456789,987654321

# Optional proxy for accessing rutor.info
# PROXY=socks5://localhost:1080
